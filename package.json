{
  "name": "auditappmini",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:backend": "npm --prefix backend run dev",
    "dev:web": "npm --prefix web run dev",
    "directus:config": "docker compose -f directus/docker-compose.yml --env-file directus/.env.example config",
    "directus:bootstrap": "node directus/scripts/bootstrap-schema.mjs",
    "directus:bootstrap:dry": "node directus/scripts/bootstrap-schema.mjs --dry-run",
    "smoke": "npm --prefix backend run smoke",
    "verify:backend": "npm --prefix backend run smoke",
    "verify:web": "npm --prefix web run build",
    "verify": "npm run verify:backend && npm run verify:web"
  }
}
