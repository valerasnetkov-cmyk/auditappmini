{
  "expo": {
    "name": "Audit Avto",
    "slug": "auditauto",
    "owner": "vsnetkov",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Камера нужна для фотофиксации осмотров, дефектов и госномера.",
        "NSLocationWhenInUseUsageDescription": "Геолокация нужна для фиксации места ДТП."
      },
      "bundleIdentifier": "com.vsnetkov.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.vsnetkov.mobile",
      "permissions": [
        "CAMERA",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "versionCode": 2
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Разрешите Аудит авто использовать камеру для фотофиксации осмотров, дефектов и госномера."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Разрешите Аудит авто использовать геолокацию для фиксации места ДТП."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "d6467f7f-f2c9-489b-9fde-7cc40cf7d6fe"
      }
    }
  }
}
