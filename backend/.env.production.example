# Auditmini backend production environment template.
# Copy to backend/.env.production or to your process manager / secret storage.
# Do not commit real production secrets.

# Runtime
NODE_ENV=production
PORT=3001

# Authentication
# Generate a unique value, for example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-secret

# SaaS access model.
# Company owners create managers/inspectors from the user panel.
# Public self-registration must stay disabled in production.
PUBLIC_REGISTRATION_ENABLED=false

# Initial platform admin seed.
# The password is used only when ADMIN_EMAIL is set and the user does not exist yet.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-admin-password

# Persistent storage.
# Prefer absolute paths on the production host.
DATABASE_PATH=./data/database.sqlite
UPLOAD_DIR=./uploads
BACKUP_DIR=./backups

# CORS.
# Use the real public web origin or a comma-separated list of allowed origins.
CORS_ORIGINS=https://app.example.com

# Upload/body limits.
MAX_FILE_SIZE=15728640
JSON_BODY_LIMIT=2mb

# Optional Directus CMS/Data Studio integration.
# Leave blank unless Directus is deployed and the backend service token is ready.
DIRECTUS_URL=
DIRECTUS_TOKEN=
DIRECTUS_DEFAULT_COMPANY_ID=

# Used in owner setup links generated for company owners.
WEB_APP_URL=https://app.example.com
OWNER_SETUP_TOKEN_TTL=7d
