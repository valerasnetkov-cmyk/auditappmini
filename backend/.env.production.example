# Auditmini backend production environment template.
# Copy to backend/.env.production or to your process manager / secret storage.
# Do not commit real production secrets.

# Runtime
NODE_ENV=production
PORT=3001

# Reverse proxy / security perimeter.
# Use 1 when backend is behind one trusted HTTPS reverse proxy.
TRUST_PROXY=1
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=15552000
SECURITY_CSP=default-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'
SECURITY_CROSS_ORIGIN_OPENER_POLICY=same-origin
SECURITY_CROSS_ORIGIN_RESOURCE_POLICY=same-site
AUTH_COOKIE_NAME=audit_session
AUTH_COOKIE_MAX_AGE_SECONDS=604800
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAME_SITE=Lax
GRACEFUL_SHUTDOWN_TIMEOUT_MS=10000
REQUEST_ID_HEADER=x-request-id
ACCESS_LOG_FORMAT=json
ACCESS_LOG_SLOW_MS=1000
ACCESS_LOG_SKIP_PATHS=/health,/api/health

# Authentication
# Generate a unique value, for example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-64-char-random-secret

# SaaS access model.
# Company owners create managers/inspectors from the user panel.
# Public self-registration must stay disabled in production.
PUBLIC_REGISTRATION_ENABLED=false
PUBLIC_DEMO_ENABLED=false
PUBLIC_DEMO_PASSWORD=

# Initial platform admin seed.
# The password is used only when ADMIN_EMAIL is set and the user does not exist yet.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-admin-password

# Persistent storage.
# Use absolute paths on the production host, outside the application release directory.
DATABASE_PATH=C:\Auditmini\data\database.sqlite
UPLOAD_DIR=C:\Auditmini\uploads
BACKUP_DIR=C:\Auditmini\backups

# CORS.
# Use the real public web origin or a comma-separated list of allowed origins.
CORS_ORIGINS=https://app.example.com

# Upload/body limits.
MAX_FILE_SIZE=15728640
MAX_IMAGE_PIXELS=40000000
JSON_BODY_LIMIT=2mb

# Odometer OCR provider.
# Use mock to keep manual confirmation only, or tesseract-cli after installing
# Tesseract 5.x and traineddata on the production host.
OCR_ODOMETER_PROVIDER=mock
TESSERACT_CMD=tesseract
TESSERACT_TIMEOUT_MS=10000

# Sensitive endpoint rate limits.
SENSITIVE_RATE_LIMIT_WINDOW_MS=900000
SENSITIVE_RATE_LIMIT_MAX=60
AUTH_ACCOUNT_RATE_LIMIT_MAX=20
PILOT_REQUEST_RATE_LIMIT_WINDOW_MS=1800000
PILOT_REQUEST_RATE_LIMIT_MAX=5

# Used in owner setup links generated for company owners.
WEB_APP_URL=https://app.example.com
OWNER_SETUP_TOKEN_TTL=7d
MFA_LOGIN_TOKEN_TTL=5m
# Billing lifecycle.
BILLING_GRACE_DAYS=7
BILLING_SUSPEND_AFTER_DAYS=14
