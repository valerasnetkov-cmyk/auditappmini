{
  "name": "audit-backend",
  "version": "1.0.0",
  "description": "Аудит Техники - Backend API",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "test:security": "node tests/role-tests.js",
    "dev": "node --watch src/server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:logs": "pm2 logs audit-backend",
    "pm2:delete": "pm2 delete audit-backend",
    "pm2:logrotate:install": "pm2 install pm2-logrotate",
    "pm2:logrotate:configure": "pm2 set pm2-logrotate:max_size 20M && pm2 set pm2-logrotate:retain 14 && pm2 set pm2-logrotate:compress true && pm2 set pm2-logrotate:dateFormat YYYY-MM-DD_HH-mm-ss",
    "backup:local": "node scripts/backup-local-data.mjs",
    "backup:verify": "node scripts/verify-local-backup.mjs",
    "doctor:launch": "node scripts/launch-doctor.mjs",
    "doctor:production": "node scripts/launch-doctor.mjs --production --doctor-env-file .env.production",
    "audit:launch": "npm audit --audit-level=moderate",
    "subscriptions:check": "node scripts/check-subscriptions.mjs",
    "smoke": "npm run smoke:health && npm run smoke:security && npm run smoke:observability && npm run smoke:shutdown && npm run smoke:production-guard && npm run smoke:auth && npm run smoke:mfa && npm run smoke:vehicles && npm run smoke:inspections && npm run smoke:isolation && npm run smoke:analytics && npm run smoke:saas-admin && npm run smoke:subscription-guard && npm run smoke:company-limits && npm run smoke:company-features && npm run smoke:backup && npm run smoke:owner-setup",
    "smoke:health": "node scripts/smoke-health.mjs",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "smoke:vehicles": "node scripts/smoke-vehicles.mjs",
    "smoke:inspections": "node scripts/smoke-inspections.mjs",
    "smoke:isolation": "node scripts/smoke-isolation.mjs",
    "smoke:analytics": "node scripts/smoke-analytics.mjs",
    "smoke:saas-admin": "node scripts/smoke-saas-admin.mjs",
    "smoke:subscription-guard": "node scripts/smoke-subscription-guard.mjs",
    "smoke:company-limits": "node scripts/smoke-company-limits.mjs",
    "smoke:company-features": "node scripts/smoke-company-features.mjs",
    "smoke:backup": "node scripts/smoke-backup.mjs",
    "smoke:mfa": "node scripts/smoke-mfa.mjs",
    "smoke:owner-setup": "node scripts/smoke-owner-setup.mjs",
    "smoke:production-guard": "node scripts/smoke-production-guard.mjs",
    "smoke:security": "node scripts/smoke-security.mjs",
    "smoke:shutdown": "node scripts/smoke-shutdown.mjs",
    "smoke:observability": "node scripts/smoke-observability.mjs"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "sql.js": "^1.10.0",
    "uuid": "^11.1.1"
  }
}
