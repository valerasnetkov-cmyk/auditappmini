# Server configuration
PORT=3001
NODE_ENV=development

# JWT Secret. In development, an ephemeral random value is used if this is missing
# (with a warning). In production this MUST be set to a strong random value (>= 32 chars).
# Generate a value via:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Redis (Epic 3.2: распределённый rate limit).
# Recommended in production (PM2 cluster / blue-green) so that
# rate limits are shared across all backend replicas.
# Format: redis://[:password@]host:port[/db]
#   - If REDIS_URL is unset: rate limiter falls back to in-memory (per-replica).
#   - If REDIS_URL is set: rate limiter uses Redis (atomic INCR + EXPIRE via Lua).
#     In production with REDIS_URL set, /api/health/ready returns 503 if Redis
#     is unreachable.
REDIS_URL=

# Admin user (auto-created if ADMIN_EMAIL is set)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Database
DATABASE_PATH=./data/database.sqlite
BACKUP_DIR=./backups

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:19006

# Local self-registration is disabled by default. Set true only for throwaway dev experiments.
PUBLIC_REGISTRATION_ENABLED=false

# Security headers
SECURITY_CSP=default-src 'none'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'
SECURITY_CROSS_ORIGIN_OPENER_POLICY=same-origin
SECURITY_CROSS_ORIGIN_RESOURCE_POLICY=same-site
AUTH_COOKIE_NAME=audit_session
AUTH_COOKIE_MAX_AGE_SECONDS=604800
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Lax

# File upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
MAX_IMAGE_PIXELS=40000000
JSON_BODY_LIMIT=2mb

WEB_APP_URL=http://localhost:3002
OWNER_SETUP_TOKEN_TTL=7d
MFA_LOGIN_TOKEN_TTL=5m
# Billing lifecycle.
BILLING_GRACE_DAYS=7
BILLING_SUSPEND_AFTER_DAYS=14
