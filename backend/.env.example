# Server configuration
PORT=3001
NODE_ENV=development

# JWT Secret (change in production!)
JWT_SECRET=dev-secret-change-in-production

# Admin user (auto-created if ADMIN_EMAIL is set)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Database
DATABASE_PATH=./src/database.sqlite
BACKUP_DIR=./backups

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3002,http://localhost:19006

# File upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
JSON_BODY_LIMIT=2mb

# Directus CMS/Data Studio integration (optional)
DIRECTUS_URL=http://localhost:8055
DIRECTUS_TOKEN=change-me-service-token
DIRECTUS_DEFAULT_COMPANY_ID=
WEB_APP_URL=http://localhost:3002
OWNER_SETUP_TOKEN_TTL=7d
