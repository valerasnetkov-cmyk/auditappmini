{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3002",
    "start": "next start -p 3002",
    "build": "node scripts/build.mjs",
    "doctor:launch": "node scripts/launch-doctor.mjs",
    "doctor:production": "node scripts/launch-doctor.mjs --production --doctor-env-file .env.production",
    "lint": "eslint",
    "smoke:static-chunks": "node scripts/smoke-static-chunks.mjs",
    "prepare:e2e": "npx playwright install",
    "prepare:e2e:chromium": "npx playwright install chromium",
    "test:e2e": "npx playwright test",
    "test:e2e:chromium": "npx playwright test --project=Chromium",
    "test:e2e:ci": "npx playwright test --reporter=github",
    "test:e2e:defects": "npx playwright test web/e2e/tests/defects-ui.spec.ts web/e2e/tests/defect-timeline.spec.ts web/e2e/tests/defect-timeline-detail.spec.ts web/e2e/tests/defect-detail-close.spec.ts web/e2e/tests/defect-detail-reopen.spec.ts",
    "test:e2e:defects:ci": "npx playwright test web/e2e/tests/defects-ui.spec.ts web/e2e/tests/defect-timeline.spec.ts web/e2e/tests/defect-timeline-detail.spec.ts web/e2e/tests/defect-detail-close.spec.ts web/e2e/tests/defect-detail-reopen.spec.ts --reporter=github"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "chart.js": "^4.5.1",
    "exceljs": "^4.4.0",
    "next": "16.2.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^18",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "playwright": "^1.40.0",
    "postcss": "^8.5.13",
    "speakeasy": "^2.0.0",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "js-yaml": "4.2.0",
    "postcss": "^8.5.13",
    "tmp": "0.2.7",
    "ws": "8.21.0",
    "uuid": "^11.1.1"
  }
}
