          "type": "integer",
          "required": true,
          "relation": {
            "collection": "companies",
            "field": "id",
            "onDelete": "CASCADE"
          },
          "note": "Связь с компанией SaaS-клиента."
        },
        {
          "field": "email",
          "label": "Email владельца",
          "type": "string",
          "required": true
