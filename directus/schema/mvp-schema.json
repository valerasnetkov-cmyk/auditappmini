        {
          "field": "phone",
          "label": "Телефон",
          "type": "string"
        },
        {
          "field": "status",
          "label": "Статус",
          "type": "string",
          "options": [
            "active",
            "inactive"
          ],
          "optionLabels": {
            "active": "Активен",
            "inactive": "Отключён"
          }
        },
        {
          "field": "created_at",
          "label": "Создано",
          "type": "datetime"
        }
      ]
    },
