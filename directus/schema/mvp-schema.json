  "collections": [
    {
      "collection": "companies",
      "label": "Компании",
      "singular": "Компания",
      "plural": "Компании",
      "icon": "business",
      "note": "Клиенты SaaS-сервиса. Создаются только администратором ресурса.",
      "displayTemplate": "{{name}}",
      "fields": [
        {
          "field": "id",
          "label": "ID",
          "type": "integer",
          "primary": true
        },
        {
          "field": "slug",
          "label": "Код компании",
          "type": "string",
          "required": true,
          "note": "Стабильный короткий код tenant-компании."
        },
        {
          "field": "name",
          "label": "Название",
          "type": "string",
          "required": true
        },
        {
          "field": "type",
          "label": "Тип компании",
          "type": "string",
          "options": [
            "insurance",
            "leasing",
            "fleet",
            "other"
          ],
          "optionLabels": {
            "insurance": "Страховая",
            "leasing": "Лизинговая",
            "fleet": "Автопарк",
            "other": "Другое"
          }
        },
        {
          "field": "country",
          "label": "Страна",
          "type": "string"
        },
        {
          "field": "region",
          "label": "Регион",
          "type": "string"
        },
        {
          "field": "billing_email",
          "label": "Email для счетов",
          "type": "string"
        },
        {
          "field": "plan_code",
          "label": "Код тарифа",
          "type": "string",
          "options": [
            "pilot",
            "standard",
            "enterprise"
          ],
          "optionLabels": {
            "pilot": "Пилот",
            "standard": "Стандарт",
            "enterprise": "Enterprise"
          },
          "note": "Код тарифа из коллекции «Тарифы». Используется backend для применения лимитов."
        },
        {
          "field": "status",
          "label": "Статус",
          "type": "string",
          "options": [
            "active",
            "inactive"
          ],
          "optionLabels": {
            "active": "Активна",
            "inactive": "Отключена"
          }
        },
        {
          "field": "settings",
          "label": "Служебные настройки",
          "type": "json"
        },
        {
          "field": "notes",
          "label": "Заметки администратора",
          "type": "text"
        },
        {
          "field": "created_at",
          "label": "Создано",
          "type": "datetime"
        }
      ]
    },
    {
